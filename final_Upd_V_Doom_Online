def check_collision(dx, dy):
    global player_x, player_y
    margin = 15 
    next_x = player_x + dx
    hit_box_x = next_x + (margin if dx > 0 else -margin)
    if MAP[int(player_y / TILE_SIZE)][int(hit_box_x / TILE_SIZE)] == 0: player_x = next_x
    next_y = player_y + dy
    hit_box_y = next_y + (margin if dy > 0 else -margin)
    if MAP[int(hit_box_y / TILE_SIZE)][int(player_x / TILE_SIZE)] == 0: player_y = next_y

def is_safe(target_x, target_y):
    margin = 12
    for dx in [-margin, margin]:
        for dy in [-margin, margin]:
            check_x = int((target_x + dx) / TILE_SIZE)
            check_y = int((target_y + dy) / TILE_SIZE)
            if check_x < 0 or check_x >= MAP_W or check_y < 0 or check_y >= MAP_H: return False
            if MAP[check_y][check_x] != 0: return False
    return True

def start_reload():
    global is_reloading, reload_end
    if is_reloading: return
    
    if current_weapon == WEAPON_PISTOL and current_pistol_ammo < max_pistol_ammo:
        is_reloading = True; reload_end = pygame.time.get_ticks() + 1500
    elif current_weapon == WEAPON_AK and current_ak_ammo < max_ak_ammo and ak_reserve_ammo > 0:
        is_reloading = True; reload_end = pygame.time.get_ticks() + 3000
    elif current_weapon == WEAPON_SHOTGUN and current_shotgun_ammo < max_shotgun_ammo and shotgun_reserve_ammo > 0:
        is_reloading = True; reload_end = pygame.time.get_ticks() + 4000

def kill_enemy(target_enemy, is_headshot):
    global current_score, spawn_rng
    target_enemy['dead'] = True
    current_score += 200 if is_headshot else 100
    
    drop_x = target_enemy['x'] + spawn_rng.randint(-10, 10) # 💡 난수 동기화
    drop_y = target_enemy['y'] + spawn_rng.randint(-10, 10)
    
    r = spawn_rng.random() # 💡 난수 동기화
    drop_type = None
    if r < 0.15: drop_type = 'shotgun_ammo' if has_shotgun else 'shotgun'
    elif r < 0.40: drop_type = 'ak_ammo' if has_ak else 'ak'
    elif r < 0.60: drop_type = 'health'
    
    if drop_type: items.append({'x': drop_x, 'y': drop_y, 'type': drop_type})
def trigger_melee():
    global is_melee_attacking, melee_timer, player_stamina
    if is_melee_attacking or is_reloading or player_dead or player_stamina < 15: return
    
    is_melee_attacking = True
    melee_timer = 15 
    player_stamina -= 15
    
    target_enemy = None
    min_dist = 60
    
    for enemy in enemies:
        if enemy['dead']: continue
        dx, dy = enemy['x'] - player_x, enemy['y'] - player_y
        dist = math.hypot(dx, dy)
        
        if dist < min_dist: 
            angle_to_enemy = math.atan2(dy, dx)
            angle_diff = angle_to_enemy - player_angle
            while angle_diff < -math.pi: angle_diff += 2 * math.pi
            while angle_diff > math.pi: angle_diff -= 2 * math.pi
            
            if abs(angle_diff) < math.pi / 2.5: 
                target_enemy = enemy
                min_dist = dist
                
    if target_enemy:
        target_enemy['hp'] -= 40
        try: send_hit_to_server(enemies.index(target_enemy), 40)
        except ValueError: pass
        # ------------------
        damage_texts.append({'text': "40", 'x': WIDTH // 2 + random.randint(-30,30), 'y': HEIGHT // 2, 'color': WHITE, 'life': 45})
        if target_enemy['hp'] <= 0: kill_enemy(target_enemy, False)

def shoot():
    global is_shooting, shoot_timer, gun_recoil, current_score, damage_texts
    global current_pistol_ammo, current_ak_ammo, current_shotgun_ammo, fire_cooldown_end
    global player_pitch, player_angle
    
    current_time = pygame.time.get_ticks()
    
    if player_dead or is_reloading or is_melee_attacking or game_state != STATE_PLAYING: return
    if current_time < fire_cooldown_end: return
    
    pellet_count = 1
    spread_angle_range = 0.0
    spread_pitch_range = 0.0
    
    if current_weapon == WEAPON_PISTOL:
        if current_pistol_ammo <= 0: start_reload(); return
        current_pistol_ammo -= 1; fire_cooldown_end = current_time + 800 
        gun_recoil = 40; base_damage = random.randint(30, 45)
        max_dmg_dist = 600.0
        # 🚀 카메라 반동 (권총)
        player_pitch += 8
        player_angle += random.uniform(-0.002, 0.002)
        
    elif current_weapon == WEAPON_AK:
        if current_ak_ammo <= 0: start_reload(); return
        current_ak_ammo -= 1; fire_cooldown_end = current_time + 80  
        gun_recoil = 20; base_damage = random.randint(20, 30)
        max_dmg_dist = 600.0
        spread_angle_range = 0.02
        spread_pitch_range = 5.0
        # 🚀 카메라 반동 (AK-47 연사)
        player_pitch += random.uniform(10, 18)
        player_angle += random.uniform(-0.015, 0.015)
        
    elif current_weapon == WEAPON_SHOTGUN: 
        if current_shotgun_ammo <= 0: start_reload(); return
        current_shotgun_ammo -= 1; fire_cooldown_end = current_time + 900
        gun_recoil = 80; base_damage = 20
        max_dmg_dist = 250.0 
        pellet_count = 5 
        spread_angle_range = 0.06 
        spread_pitch_range = 15.0 
        # 🚀 카메라 반동 (샷건)
        player_pitch += 40
        player_angle += random.uniform(-0.02, 0.02)

    # 반동으로 화면이 넘어가는 것을 방지하기 위해 각도 제한
    player_pitch = max(-HEIGHT//2 + 50, min(HEIGHT//2 - 50, player_pitch))
    is_shooting = True; shoot_timer = 8

    for p in range(pellet_count):
        angle_offset = random.uniform(-spread_angle_range, spread_angle_range) if pellet_count > 1 else 0
        pitch_offset = random.uniform(-spread_pitch_range, spread_pitch_range) if pellet_count > 1 else 0
        
        shot_angle = player_angle + angle_offset
        shot_pitch = player_pitch + pitch_offset
        
        ray_idx = int(((shot_angle - (player_angle - current_fov/2)) / current_fov) * CASTED_RAYS)
        ray_idx = max(0, min(CASTED_RAYS - 1, ray_idx))
        wall_dist = Z_BUFFER[ray_idx]
        
        target_enemy, min_dist, is_headshot = None, wall_dist, False

        for enemy in enemies:
            if enemy['dead']: continue
            dx, dy = enemy['x'] - player_x, enemy['y'] - player_y
            dist = math.hypot(dx, dy)
            safe_dist = max(1.0, dist)
            
            angle_to_enemy = math.atan2(dy, dx)
            angle_diff = angle_to_enemy - shot_angle
            while angle_diff < -math.pi: angle_diff += 2 * math.pi
            while angle_diff > math.pi: angle_diff -= 2 * math.pi
            
            if abs(angle_diff) < current_fov / 2 and dist < min_dist:
                wall_height = (TILE_SIZE * current_proj_dist) / safe_dist
                sprite_height = wall_height * 0.7
                sprite_width = sprite_height * 0.5
                
                monster_bottom = HEIGHT // 2 + wall_height // 2 + shot_pitch
                monster_top = monster_bottom - sprite_height
                
                pixel_offset = (angle_diff / (current_fov / 2)) * (WIDTH / 2)
                hit_y = HEIGHT // 2
                
                if abs(pixel_offset) < sprite_width / 2:
                    if monster_top <= hit_y <= monster_bottom:
                        target_enemy, min_dist = enemy, dist
                        is_headshot = (monster_top <= hit_y <= monster_top + sprite_height * 0.25)

        if target_enemy:
            distance_ratio = min(min_dist / max_dmg_dist, 1.0)
            damage_multiplier = 1.0 - (0.8 * distance_ratio) 
            
            if current_weapon == WEAPON_SHOTGUN:
                damage = 30 if is_headshot else 20
            else:
                final_base_damage = base_damage * damage_multiplier
                damage = int(final_base_damage * 1.5) if is_headshot else int(final_base_damage)
                
            if damage > 0:
                target_enemy['hp'] -= damage
                try: send_hit_to_server(enemies.index(target_enemy), damage)
                except ValueError: pass
                offset_x, offset_y = random.randint(-40, 40), random.randint(-40, 0)
                damage_texts.append({'text': f"{damage}", 'x': WIDTH // 2 + offset_x, 'y': HEIGHT // 2 + offset_y, 'color': YELLOW if is_headshot else WHITE, 'life': 45})
                
                if target_enemy['hp'] <= 0 and not target_enemy['dead']: kill_enemy(target_enemy, is_headshot)
        else:
            target_x = player_x + math.cos(shot_angle) * (min_dist - 2)
            target_y = player_y + math.sin(shot_angle) * (min_dist - 2)
            wall_h_at_shot = (TILE_SIZE * current_proj_dist) / max(1.0, min_dist)
            hit_ratio = (-shot_pitch) / wall_h_at_shot if wall_h_at_shot > 0 else 0
            bullet_holes.append({'x': target_x, 'y': target_y, 'ratio': hit_ratio, 'life': 300})

def draw_wall(ray, depth, angle):
    global Z_BUFFER
    depth *= math.cos(angle - player_angle)
    safe_depth = max(1.0, depth) 
    wall_height = (TILE_SIZE * current_proj_dist) / safe_depth
    wall_height = min(wall_height, HEIGHT * 4) 
    
    fog_ratio = min(1.0, safe_depth / MAX_DEPTH)
    intensity = max(0.0, 1.0 - fog_ratio)
    
    r = int(DOOM_WALL_BASE[0] * intensity + FOG_COLOR[0] * (1 - intensity))
    g = int(DOOM_WALL_BASE[1] * intensity + FOG_COLOR[1] * (1 - intensity))
    b = int(DOOM_WALL_BASE[2] * intensity + FOG_COLOR[2] * (1 - intensity))
    
    y_start = HEIGHT // 2 - wall_height // 2 + player_pitch
    
    rect_x = int(ray * SCALE)
    next_x = int((ray + 1) * SCALE) 
    rect_w = next_x - rect_x
    
    pygame.draw.rect(virtual_screen, (r, g, b), (rect_x, y_start, rect_w, wall_height))
    Z_BUFFER[ray] = depth

def draw_items_and_enemies():
    render_list = []
    for item in items: render_list.append({'type': 'item', 'obj': item, 'dist': math.hypot(item['x']-player_x, item['y']-player_y)})
    for enemy in enemies:
        if not enemy['dead']: render_list.append({'type': 'enemy', 'obj': enemy, 'dist': math.hypot(enemy['x']-player_x, enemy['y']-player_y)})
    if other_pos["x"] >= 0 and math.hypot(other_pos["x"] - player_x, other_pos["y"] - player_y) > 5:
        render_list.append({'type': 'other_player', 'obj': {'x': other_pos["x"], 'y': other_pos["y"]}, 'dist': math.hypot(other_pos["x"] - player_x, other_pos["y"] - player_y)})  

    render_list.sort(key=lambda x: x['dist'], reverse=True)
    
    for entity in render_list:
        obj = entity['obj']
        dist = entity['dist']
        safe_dist = max(1.0, dist)
        
        dx, dy = obj['x'] - player_x, obj['y'] - player_y
        angle_to_obj = math.atan2(dy, dx)
        angle_diff = angle_to_obj - player_angle
        while angle_diff < -math.pi: angle_diff += 2 * math.pi
        while angle_diff > math.pi: angle_diff -= 2 * math.pi
        
        if abs(angle_diff) < current_fov / 2 + 0.3:
            screen_x = (WIDTH / 2) + (angle_diff / (current_fov / 2)) * (WIDTH / 2)
            wall_height = (TILE_SIZE * current_proj_dist) / safe_dist
            
            ray_idx = int(screen_x / SCALE)
            if 0 <= ray_idx < CASTED_RAYS and dist < Z_BUFFER[ray_idx] + 20:
                fog_ratio = min(1.0, dist / MAX_DEPTH)
                intensity = max(0.0, 1.0 - fog_ratio)
                
                if entity['type'] == 'enemy':
                    sprite_height = wall_height * 0.7
                    sprite_width = sprite_height * 0.5
                    monster_bottom = HEIGHT // 2 + wall_height // 2 + player_pitch
                    monster_top = monster_bottom - sprite_height
                    
                    body_color = (int(180*intensity + FOG_COLOR[0]*(1-intensity)), int(50*intensity + FOG_COLOR[1]*(1-intensity)), int(50*intensity + FOG_COLOR[2]*(1-intensity)))
                    body_rect = pygame.Rect(screen_x - sprite_width // 2, monster_top + sprite_height * 0.25, sprite_width, sprite_height * 0.75)
                    pygame.draw.rect(virtual_screen, body_color, body_rect)
                    
                    head_color = (int(200*intensity + FOG_COLOR[0]*(1-intensity)), int(160*intensity + FOG_COLOR[1]*(1-intensity)), int(140*intensity + FOG_COLOR[2]*(1-intensity)))
                    head_rx, head_ry = int(sprite_width * 0.35), int(sprite_height * 0.125)
                    pygame.draw.ellipse(virtual_screen, head_color, (int(screen_x)-head_rx, int(monster_top+head_ry)-head_ry, head_rx*2, head_ry*2))
                    
                    eye_color = (int(255*intensity), 0, 0)
                    eye_w, eye_h = max(2, int(head_rx * 0.3)), max(2, int(head_ry * 0.3))
                    eye_y = int(monster_top + head_ry - head_ry * 0.2)
                    pygame.draw.ellipse(virtual_screen, eye_color, (int(screen_x) - int(head_rx * 0.5) - eye_w//2, eye_y, eye_w, eye_h))
                    pygame.draw.ellipse(virtual_screen, eye_color, (int(screen_x) + int(head_rx * 0.5) - eye_w//2, eye_y, eye_w, eye_h))
                    
                    hp_ratio = max(0, obj['hp']) / 150.0
                    bar_w = sprite_width
                    bar_h = max(4, int(sprite_height * 0.05))
                    bar_x = screen_x - bar_w // 2
                    bar_y = monster_top - bar_h - max(5, int(wall_height * 0.05))
                    pygame.draw.rect(virtual_screen, (80, 0, 0), (bar_x, bar_y, bar_w, bar_h))
                    pygame.draw.rect(virtual_screen, (0, 180, 0), (bar_x, bar_y, int(bar_w * hp_ratio), bar_h))
                    
                elif entity['type'] == 'item':
                    item_size = max(5, int(wall_height * 0.15))
                    item_bottom = HEIGHT // 2 + wall_height // 2 + player_pitch
                    
                    if obj['type'] == 'ak':
                        color = (int(139*intensity), int(69*intensity), int(19*intensity)) 
                        pygame.draw.rect(virtual_screen, color, (screen_x - item_size, item_bottom - item_size//2, item_size*2, item_size//2))
                        txt = ITEM_FONT.render("AK-47", True, WHITE)
                    elif obj['type'] == 'shotgun':
                        stock_color = (int(100*intensity), int(50*intensity), int(20*intensity)) 
                        barrel_color = (int(60*intensity), int(60*intensity), int(60*intensity))
                        pygame.draw.rect(virtual_screen, stock_color, (screen_x - item_size, item_bottom - item_size//2, item_size, item_size//2))
                        pygame.draw.rect(virtual_screen, barrel_color, (screen_x, item_bottom - item_size//2, item_size*1.3, item_size//2))
                        txt = ITEM_FONT.render("SHOTGUN", True, WHITE)
                    elif obj['type'] == 'ak_ammo':
                        color = (int(180*intensity), int(130*intensity), int(20*intensity)) 
                        pygame.draw.rect(virtual_screen, color, (screen_x - item_size//2, item_bottom - item_size, item_size, item_size))
                        txt = ITEM_FONT.render("AK AMMO", True, YELLOW)
                    elif obj['type'] == 'shotgun_ammo':
                        color = (int(200*intensity), 0, 0) 
                        pygame.draw.rect(virtual_screen, color, (screen_x - item_size//2, item_bottom - item_size, item_size, item_size))
                        txt = ITEM_FONT.render("SG AMMO", True, RED)
                    elif obj['type'] == 'health': 
                        color = (0, int(150*intensity), 0) 
                        pygame.draw.rect(virtual_screen, color, (screen_x - item_size//2, item_bottom - item_size, item_size, item_size))
                        pygame.draw.line(virtual_screen, WHITE, (screen_x, item_bottom - item_size + 2), (screen_x, item_bottom - 2), 2)
                        pygame.draw.line(virtual_screen, WHITE, (screen_x - item_size//2 + 2, item_bottom - item_size//2), (screen_x + item_size//2 - 2, item_bottom - item_size//2), 2)
                        txt = ITEM_FONT.render("HP", True, RED)
                    
                    txt.set_alpha(int(255 * max(0.3, intensity)))
                    virtual_screen.blit(txt, (screen_x - txt.get_width()//2, item_bottom - item_size - 20))

def draw_bullet_holes():
    for hole in bullet_holes[:]:
        if game_state == STATE_PLAYING: hole['life'] -= 1
        if hole['life'] <= 0:
            bullet_holes.remove(hole); continue
            
        dx, dy = hole['x'] - player_x, hole['y'] - player_y
        dist = math.hypot(dx, dy)
        angle_diff = math.atan2(dy, dx) - player_angle
        while angle_diff < -math.pi: angle_diff += 2 * math.pi
        while angle_diff > math.pi: angle_diff -= 2 * math.pi
        
        if abs(angle_diff) < current_fov / 2:
            screen_x = (WIDTH / 2) + (angle_diff / (current_fov / 2)) * (WIDTH / 2)
            ray_idx = int(screen_x / SCALE)
            if 0 <= ray_idx < CASTED_RAYS and dist < Z_BUFFER[ray_idx] + 10:
                current_wall_height = (TILE_SIZE * current_proj_dist) / max(1.0, dist)
                screen_y = HEIGHT // 2 + player_pitch + hole['ratio'] * current_wall_height
                intensity = max(0.1, 1.0 - (dist / MAX_DEPTH))
                pygame.draw.circle(virtual_screen, (int(20*intensity), int(20*intensity), int(20*intensity)), (int(screen_x), int(screen_y)), max(2, int((TILE_SIZE * 15) / max(1.0, dist))))

