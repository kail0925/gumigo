def network_thread():
    global other_pos, pending_hits, received_hits
    while is_multiplayer:
        try:
            px = player_x / 64 if 'player_x' in globals() else 0.0
            py = player_y / 64 if 'player_y' in globals() else 0.0
            
            hits_str = "-".join(pending_hits)
            pending_hits.clear()
            msg = f"{px},{py}/{hits_str}\n"
            s.sendall(msg.encode('utf-8'))

            data = s.recv(1024).decode('utf-8')
            if not data: break
            msgs = data.strip().split('\n')
            if msgs and msgs[-1]:
                latest = msgs[-1].split('|')
                if len(latest) >= 2:
                    p1_data, p2_data = latest[0].split('/'), latest[1].split('/')
                    p1_x, p1_y = map(float, p1_data[0].split(','))
                    p2_x, p2_y = map(float, p2_data[0].split(','))
                    
                    if my_id == 1:
                        other_pos["x"], other_pos["y"] = p2_x * 64, p2_y * 64
                        if len(p2_data) > 1 and p2_data[1]: received_hits.extend(p2_data[1].split('-'))
                    else:
                        other_pos["x"], other_pos["y"] = p1_x * 64, p1_y * 64
                        if len(p1_data) > 1 and p1_data[1]: received_hits.extend(p1_data[1].split('-'))
        except Exception as e:
            pass
        time.sleep(0.01)

if is_multiplayer:
    threading.Thread(target=network_thread, daemon=True).start()

def send_hit_to_server(enemy_index, damage):
    if is_multiplayer: pending_hits.append(f"{enemy_index}:{damage}")

def sync_enemy_hp_from_server(enemies_list):
    global received_hits, current_score
    if is_multiplayer and received_hits:
        for hit in received_hits:
            if ":" in hit:
                e_idx, e_dmg = map(int, hit.split(':'))
                if 0 <= e_idx < len(enemies_list) and not enemies_list[e_idx]['dead']:
                    enemies_list[e_idx]['hp'] -= e_dmg
                    if enemies_list[e_idx]['hp'] <= 0:
                        kill_enemy(enemies_list[e_idx], False) # 친구의 킬 함수 연동
        received_hits.clear()
