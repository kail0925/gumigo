def draw_entities():
    render_list = [{'type': 'item', 'obj': i, 'dist': math.hypot(i['x']-player_x, i['y']-player_y)} for i in items]
    render_list.extend([{'type': 'enemy', 'obj': e, 'dist': math.hypot(e['x']-player_x, e['y']-player_y)} for e in enemies if not e['dead']])
    if other_pos["x"] >= 0 and math.hypot(other_pos["x"] - player_x, other_pos["y"] - player_y) > 5:
        render_list.append({'type': 'other_player', 'obj': {'x': other_pos["x"], 'y': other_pos["y"]}, 'dist': math.hypot(other_pos["x"] - player_x, other_pos["y"] - player_y)})
            
    render_list.sort(key=lambda x: x['dist'], reverse=True)
    for ent in render_list:
        obj, dist = ent['obj'], max(1.0, ent['dist'])
        angle_diff = math.atan2(obj['y'] - player_y, obj['x'] - player_x) - player_angle
        while angle_diff < -math.pi: angle_diff += 2 * math.pi
        while angle_diff > math.pi: angle_diff -= 2 * math.pi
        
        if abs(angle_diff) < current_fov / 2 + 0.3:
            screen_x = (WIDTH / 2) + (angle_diff / (current_fov / 2)) * (WIDTH / 2)
            ray_idx = int(screen_x / SCALE)
            if 0 <= ray_idx < CASTED_RAYS and dist < Z_BUFFER[ray_idx] + 20:
                intensity = max(0.0, 1.0 - min(1.0, dist / MAX_DEPTH))
                wall_height = (TILE_SIZE * current_proj_dist) / dist
                bottom_y = HEIGHT // 2 + wall_height // 2 + player_pitch
                
                if ent['type'] == 'other_player':
                    sprite_size = int(wall_height * 0.7)
                    scaled_surf = pygame.transform.scale(other_player_surf, (sprite_size, sprite_size))
                    darken = pygame.Surface(scaled_surf.get_size(), pygame.SRCALPHA)
                    darken.fill((0, 0, 0, int(255 * (1 - intensity))))
                    scaled_surf.blit(darken, (0, 0), special_flags=pygame.BLEND_RGBA_SUB)
                    virtual_screen.blit(scaled_surf, (screen_x - sprite_size // 2, bottom_y - sprite_size))
                
                elif ent['type'] == 'enemy':
                    sh, sw = wall_height * 0.7, wall_height * 0.35
                    top_y = bottom_y - sh
                    pygame.draw.rect(virtual_screen, (int(180*intensity+FOG_COLOR[0]*(1-intensity)), int(50*intensity+FOG_COLOR[1]*(1-intensity)), int(50*intensity+FOG_COLOR[2]*(1-intensity))), (screen_x - sw // 2, top_y + sh * 0.25, sw, sh * 0.75))
                    hrx, hry = int(sw * 0.35), int(sh * 0.125)
                    pygame.draw.ellipse(virtual_screen, (int(200*intensity+FOG_COLOR[0]*(1-intensity)), int(160*intensity+FOG_COLOR[1]*(1-intensity)), int(140*intensity+FOG_COLOR[2]*(1-intensity))), (int(screen_x)-hrx, int(top_y+hry)-hry, hrx*2, hry*2))
                    
                elif ent['type'] == 'item':
                    size = max(5, int(wall_height * 0.15))
                    if obj['type'] == 'ak':
                        pygame.draw.rect(virtual_screen, (int(139*intensity), int(69*intensity), int(19*intensity)), (screen_x - size, bottom_y - size//2, size*2, size//2))
                        txt = ITEM_FONT.render("AK-47", True, WHITE)
                    elif obj['type'] == 'ammo':
                        pygame.draw.rect(virtual_screen, (int(200*intensity), 0, 0), (screen_x - size//2, bottom_y - size, size, size))
                        txt = ITEM_FONT.render("AMMO", True, YELLOW)
                    else: 
                        pygame.draw.rect(virtual_screen, (0, int(150*intensity), 0), (screen_x - size//2, bottom_y - size, size, size))
                        txt = ITEM_FONT.render("HP", True, RED)
                    txt.set_alpha(int(255 * max(0.3, intensity)))
                    virtual_screen.blit(txt, (screen_x - txt.get_width()//2, bottom_y - size - 20))

def draw_hud():
