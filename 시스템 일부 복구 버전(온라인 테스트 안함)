    pygame.draw.rect(virtual_screen, GREEN, (20, HEIGHT - 40, max(0, player_health)*2, 25))
    pygame.draw.rect(virtual_screen, (0, 30, 60), (20, HEIGHT - 12, 200, 8))
    pygame.draw.rect(virtual_screen, (100, 200, 255), (20, HEIGHT - 12, max(0, player_stamina)*2, 8)) 
    virtual_screen.blit(PROG_FONT.render(f"HP: {int(max(0, player_health))}", True, WHITE), (20, HEIGHT - 80))
    virtual_screen.blit(PROG_FONT.render(f"SCORE: {current_score}", True, WHITE), (20, 20))
    
    ammo_str = f"Reloading... {(reload_end - pygame.time.get_ticks())/1000.0:.1f}s" if is_reloading else (f"[PISTOL] {current_pistol_ammo} / ∞" if current_weapon == WEAPON_PISTOL else f"[AK-47] {current_ak_ammo} / {ak_reserve_ammo}")
    virtual_screen.blit(PROG_FONT.render(ammo_str, True, YELLOW if is_reloading else WHITE), (WIDTH - 280, HEIGHT - 40)) 

