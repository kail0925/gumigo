def get_virtual_mouse_pos(mouse_x, mouse_y):
    win_w, win_h = screen.get_size()
    ratio = min(win_w / WIDTH, win_h / HEIGHT)
    scaled_w, scaled_h = int(WIDTH * ratio), int(HEIGHT * ratio)
    return ((mouse_x - (win_w - scaled_w) // 2) / ratio, (mouse_y - (win_h - scaled_h) // 2) / ratio)

def init_game():
    global player_angle, player_pitch, player_health, player_dead, game_state
    global enemies, items, bullet_holes, damage_texts, Z_BUFFER
    global current_weapon, has_ak, current_pistol_ammo, current_ak_ammo, ak_reserve_ammo
    global is_reloading, reload_end, heal_effect_timer, damage_flash_timer
    global player_stamina, fire_cooldown_end, player_invincible_end
    
    global spawn_rng, last_spawn_score, current_score
    current_score, last_spawn_score = 0, 0
    spawn_rng = random.Random(777)

    player_health, player_stamina, player_dead = 100.0, max_stamina, False
    game_state, player_angle, player_pitch = STATE_PLAYING, math.pi / 2, 0.0
    current_weapon, has_ak = WEAPON_PISTOL, False
    current_pistol_ammo, current_ak_ammo, ak_reserve_ammo = max_pistol_ammo, max_ak_ammo, 0
    is_reloading, reload_end, fire_cooldown_end, player_invincible_end = False, 0, 0, 0
    heal_effect_timer, damage_flash_timer = 0, 0
    
    bullet_holes, damage_texts, enemies, items = [], [], [], []
    Z_BUFFER = [MAX_DEPTH] * CASTED_RAYS

    generate_random_map(24, 24)
    spawn_enemies(12)

def generate_random_map(w, h):
    global MAP, MAP_W, MAP_H, player_x, player_y, spawn_rng
    MAP_W, MAP_H = w, h
    MAP = [[0 if spawn_rng.random() > 0.3 else 1 for _ in range(w)] for _ in range(h)]
    for y in range(h): MAP[y][0] = MAP[y][w-1] = 1
    for x in range(w): MAP[0][x] = MAP[h-1][x] = 1

    cx, cy = w // 2, h // 2
    for dy in range(-1, 2):
        for dx in range(-1, 2): MAP[cy + dy][cx + dx] = 0
    MAP[cy][cx + 1] = 0 
    
    player_x = ((cx + 1) if my_id == 2 else cx) * TILE_SIZE + TILE_SIZE // 2
    player_y = cy * TILE_SIZE + TILE_SIZE // 2

def spawn_enemies(count):
    global enemies, spawn_rng
    for _ in range(count):
        for _ in range(50):
            gx, gy = spawn_rng.randint(1, MAP_W-2), spawn_rng.randint(1, MAP_H-2)
            if MAP[gy][gx] == 0 and math.hypot(gx - MAP_W//2, gy - MAP_H//2) > 4:
                enemies.append({'x': gx*TILE_SIZE + TILE_SIZE//2, 'y': gy*TILE_SIZE + TILE_SIZE//2, 'hp': 100, 'speed': spawn_rng.uniform(0.6, 1.4), 'dead': False, 'next_attack_time': 0})
                break

def check_collision(dx, dy):
    global player_x, player_y
    margin = 15 
    if MAP[int(player_y / TILE_SIZE)][int((player_x + dx + (margin if dx>0 else -margin)) / TILE_SIZE)] == 0: player_x += dx
    if MAP[int((player_y + dy + (margin if dy>0 else -margin)) / TILE_SIZE)][int(player_x / TILE_SIZE)] == 0: player_y += dy

def is_safe(target_x, target_y):
    for dx in [-12, 12]:
        for dy in [-12, 12]:
            cx, cy = int((target_x + dx) / TILE_SIZE), int((target_y + dy) / TILE_SIZE)
            if cx < 0 or cx >= MAP_W or cy < 0 or cy >= MAP_H or MAP[cy][cx] != 0: return False
    return True

def start_reload():
    global is_reloading, reload_end
    if is_reloading: return
    if current_weapon == WEAPON_PISTOL and current_pistol_ammo < max_pistol_ammo:
        is_reloading, reload_end = True, pygame.time.get_ticks() + 1500
    elif current_weapon == WEAPON_AK and current_ak_ammo < max_ak_ammo and ak_reserve_ammo > 0:
        is_reloading, reload_end = True, pygame.time.get_ticks() + 3000

def shoot():
    global is_shooting, shoot_timer, gun_recoil, current_score, damage_texts
    global current_pistol_ammo, current_ak_ammo, fire_cooldown_end, items
    current_time = pygame.time.get_ticks()
    
    if player_dead or is_reloading or game_state != STATE_PLAYING or current_time < fire_cooldown_end: return
    
    if current_weapon == WEAPON_PISTOL:
        if current_pistol_ammo <= 0: start_reload(); return
        current_pistol_ammo -= 1; fire_cooldown_end = current_time + 800 
        gun_recoil, base_damage = 40, random.randint(30, 45)
    else:
        if current_ak_ammo <= 0: start_reload(); return
        current_ak_ammo -= 1; fire_cooldown_end = current_time + 80  
        gun_recoil, base_damage = 20, random.randint(20, 30)

    is_shooting, shoot_timer = True, 8
    target_enemy, min_dist, is_headshot = None, Z_BUFFER[CASTED_RAYS // 2], False

    for enemy in enemies:
        if enemy['dead']: continue
        dx, dy = enemy['x'] - player_x, enemy['y'] - player_y
        dist, angle_diff = math.hypot(dx, dy), math.atan2(dy, dx) - player_angle
        while angle_diff < -math.pi: angle_diff += 2 * math.pi
        while angle_diff > math.pi: angle_diff -= 2 * math.pi
        
        if abs(angle_diff) < current_fov / 2 and dist < min_dist:
            sprite_height = ((TILE_SIZE * current_proj_dist) / max(1.0, dist)) * 0.7
            sprite_width = sprite_height * 0.5
            monster_top = (HEIGHT // 2 + ((TILE_SIZE * current_proj_dist) / max(1.0, dist)) // 2 + player_pitch) - sprite_height
            
            if abs((angle_diff / (current_fov / 2)) * (WIDTH / 2)) < sprite_width / 2 and monster_top <= HEIGHT // 2 <= monster_top + sprite_height:
                target_enemy, min_dist = enemy, dist
                is_headshot = (monster_top <= HEIGHT // 2 <= monster_top + sprite_height * 0.25)

    if target_enemy:
        damage = int((base_damage * (1.0 - 0.8 * min(min_dist / 600.0, 1.0))) * (1.5 if is_headshot else 1.0))
        target_enemy['hp'] -= damage
        try: send_hit_to_server(enemies.index(target_enemy), damage)
        except ValueError: pass

        damage_texts.append({'text': f"{damage}", 'x': WIDTH//2 + random.randint(-30,30), 'y': HEIGHT//2 + random.randint(-30,0), 'color': YELLOW if is_headshot else WHITE, 'life': 45})
        
        if target_enemy['hp'] <= 0:
            target_enemy['dead'] = True
            current_score += 200 if is_headshot else 100
            drop_x, drop_y = target_enemy['x'] + random.randint(-10, 10), target_enemy['y'] + random.randint(-10, 10)
            rand_val = random.random()
            if not has_ak:
                if rand_val < 0.3: items.append({'x': drop_x, 'y': drop_y, 'type': 'ak'})
                elif rand_val < 0.6: items.append({'x': drop_x, 'y': drop_y, 'type': 'health'})
            else:
                if rand_val < 0.5: items.append({'x': drop_x, 'y': drop_y, 'type': 'ammo'})
                elif rand_val < 0.8: items.append({'x': drop_x, 'y': drop_y, 'type': 'health'})
    else:
        bullet_holes.append({'x': player_x + math.cos(player_angle)*(min_dist-2), 'y': player_y + math.sin(player_angle)*(min_dist-2), 'ratio': (-player_pitch) / ((TILE_SIZE * current_proj_dist) / max(1.0, min_dist)) if min_dist>0 else 0, 'life': 300})

def draw_wall(ray, depth, angle):
    global Z_BUFFER
    safe_depth = max(1.0, depth * math.cos(angle - player_angle))
    wall_height = min((TILE_SIZE * current_proj_dist) / safe_depth, HEIGHT * 4) 
    intensity = max(0.0, 1.0 - min(1.0, safe_depth / MAX_DEPTH))
    r, g, b = [int(DOOM_WALL_BASE[i] * intensity + FOG_COLOR[i] * (1 - intensity)) for i in range(3)]
    rect_x = int(ray * SCALE)
    pygame.draw.rect(virtual_screen, (r, g, b), (rect_x, HEIGHT // 2 - wall_height // 2 + player_pitch, int((ray + 1) * SCALE) - rect_x, wall_height))
    Z_BUFFER[ray] = safe_depth

# --- [복구됨] 탄흔, 텍스트, 미니맵, 총기 디테일 그리기 ---
def draw_bullet_holes():
    for hole in bullet_holes[:]:
        if game_state == STATE_PLAYING: hole['life'] -= 1
        if hole['life'] <= 0:
            bullet_holes.remove(hole)
            continue
        dist = math.hypot(hole['x'] - player_x, hole['y'] - player_y)
        angle_diff = math.atan2(hole['y'] - player_y, hole['x'] - player_x) - player_angle
        while angle_diff < -math.pi: angle_diff += 2 * math.pi
        while angle_diff > math.pi: angle_diff -= 2 * math.pi
        if abs(angle_diff) < current_fov / 2:
            screen_x = (WIDTH / 2) + (angle_diff / (current_fov / 2)) * (WIDTH / 2)
            ray_idx = int(screen_x / SCALE)
            if 0 <= ray_idx < CASTED_RAYS and dist < Z_BUFFER[ray_idx] + 10:
                screen_y = HEIGHT // 2 + player_pitch + hole['ratio'] * ((TILE_SIZE * current_proj_dist) / max(1.0, dist))
                intensity = max(0.1, 1.0 - (dist / MAX_DEPTH))
                pygame.draw.circle(virtual_screen, (int(20*intensity), int(20*intensity), int(20*intensity)), (int(screen_x), int(screen_y)), max(2, int((TILE_SIZE * 15) / max(1.0, dist))))

def draw_damage_texts():
    for t in damage_texts[:]:
        if game_state == STATE_PLAYING: t['life'] -= 1; t['y'] -= 1
        if t['life'] <= 0:
            damage_texts.remove(t); continue
        alpha = min(255, t['life'] * 8)
        text_surf = DMG_FONT.render(t['text'], True, t['color']); text_surf.set_alpha(alpha)
        shadow_surf = DMG_FONT.render(t['text'], True, BLACK); shadow_surf.set_alpha(alpha)
        virtual_screen.blit(shadow_surf, (t['x'] + 1, t['y'] + 1))
        virtual_screen.blit(text_surf, (t['x'], t['y']))

def draw_weapon():
    global gun_recoil
    gun_base_pos = HEIGHT + 250 if is_reloading else HEIGHT + 80 + gun_recoil
    if current_weapon == WEAPON_PISTOL:
        pygame.draw.rect(virtual_screen, GRAY, (WIDTH//2 - 40, gun_base_pos - 150, 80, 150))
        pygame.draw.rect(virtual_screen, (40, 40, 40), (WIDTH//2 - 20, gun_base_pos - 220, 40, 100))
        pygame.draw.circle(virtual_screen, BLACK, (WIDTH//2, gun_base_pos - 220), 18)
    elif current_weapon == WEAPON_AK:
        pygame.draw.rect(virtual_screen, BROWN, (WIDTH//2 - 40, gun_base_pos - 150, 80, 150))
        pygame.draw.rect(virtual_screen, (30, 30, 30), (WIDTH//2 - 25, gun_base_pos - 300, 50, 180))
        pygame.draw.rect(virtual_screen, BROWN, (WIDTH//2 - 25, gun_base_pos - 200, 50, 60))
        pygame.draw.circle(virtual_screen, BLACK, (WIDTH//2, gun_base_pos - 300), 15)
        
    if is_shooting and shoot_timer > 4 and not is_reloading:
        flash_y = gun_base_pos - 230 if current_weapon == WEAPON_PISTOL else gun_base_pos - 320
        pygame.draw.circle(virtual_screen, (255, 200, 50), (WIDTH//2, flash_y), 30 if current_weapon == WEAPON_AK else 25)
        pygame.draw.circle(virtual_screen, (255, 100, 0), (WIDTH//2, flash_y), 15 if current_weapon == WEAPON_AK else 12)  
    if game_state == STATE_PLAYING: gun_recoil = max(0, gun_recoil - (10 if current_weapon == WEAPON_AK else 5))

def draw_minimap():
    margin, ts = 20, 5  
    start_x, start_y = WIDTH - MAP_W*ts - margin, margin 
    minimap_surf = pygame.Surface((MAP_W*ts, MAP_H*ts), pygame.SRCALPHA)
    minimap_surf.fill((0, 0, 0, 150)); virtual_screen.blit(minimap_surf, (start_x, start_y))
    
    for y, row in enumerate(MAP):
        for x, tile in enumerate(row):
            if tile == 1: pygame.draw.rect(virtual_screen, GRAY, (start_x + x*ts, start_y + y*ts, ts, ts))
                
    pmx, pmy = int((player_x / TILE_SIZE) * ts), int((player_y / TILE_SIZE) * ts)
    pygame.draw.circle(virtual_screen, GREEN, (start_x + pmx, start_y + pmy), ts // 2)
    pygame.draw.line(virtual_screen, GREEN, (start_x + pmx, start_y + pmy), (start_x + pmx + math.cos(player_angle)*ts*2, start_y + pmy + math.sin(player_angle)*ts*2), 1)
    
    for enemy in enemies:
        if not enemy['dead']: pygame.draw.circle(virtual_screen, RED, (start_x + int((enemy['x']/TILE_SIZE)*ts), start_y + int((enemy['y']/TILE_SIZE)*ts)), max(1, ts//3))
    for item in items:
        pygame.draw.circle(virtual_screen, YELLOW if item['type']=='ak' else RED if item['type']=='ammo' else GREEN, (start_x + int((item['x']/TILE_SIZE)*ts), start_y + int((item['y']/TILE_SIZE)*ts)), max(1, ts//3))
    if other_pos["x"] >= 0 and other_pos["y"] >= 0:
        pygame.draw.circle(virtual_screen, (0,0,255), (start_x + int((other_pos["x"]/TILE_SIZE)*ts), start_y + int((other_pos["y"]/TILE_SIZE)*ts)), max(1, ts//2))
