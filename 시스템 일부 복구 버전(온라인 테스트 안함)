    else:
        pygame.draw.line(virtual_screen, crosshair_c, (cx - 12, cy), (cx + 12, cy), 2)
        pygame.draw.line(virtual_screen, crosshair_c, (cx, cy - 12), (cx, cy + 12), 2)

# ==========================================
init_game()

while True:
    keys = pygame.key.get_pressed()
    current_time = pygame.time.get_ticks()
    is_aiming = pygame.mouse.get_pressed()[2] and not is_reloading and not player_dead
    
    sync_enemy_hp_from_server(enemies)

    current_fov += ((math.pi / 6 if is_aiming else BASE_FOV) - current_fov) * 0.15
    STEP_ANGLE, current_proj_dist = current_fov / CASTED_RAYS, (WIDTH / 2) / math.tan(current_fov / 2)
    
    for event in pygame.event.get():
        if event.type == pygame.QUIT: pygame.quit(); exit()
        if event.type == pygame.MOUSEBUTTONDOWN and event.button == 1:
            if game_state == STATE_PLAYING and not player_dead and current_weapon == WEAPON_PISTOL: shoot()
            elif game_state == STATE_PAUSED:
                vpos = get_virtual_mouse_pos(*pygame.mouse.get_pos())
                if resume_btn_rect.collidepoint(vpos): game_state = STATE_PLAYING; pygame.mouse.set_visible(False); pygame.event.set_grab(True); pygame.mouse.get_rel()
                elif restart_btn_rect.collidepoint(vpos): init_game(); game_state = STATE_PLAYING; pygame.mouse.set_visible(False); pygame.event.set_grab(True)
                elif quit_btn_rect.collidepoint(vpos): pygame.quit(); exit()
        elif event.type == pygame.KEYDOWN:
            if event.key == pygame.K_ESCAPE:
                game_state = STATE_PAUSED if game_state == STATE_PLAYING else STATE_PLAYING
                pygame.mouse.set_visible(game_state == STATE_PAUSED); pygame.event.set_grab(game_state == STATE_PLAYING)
            if game_state == STATE_PLAYING:
                if event.key == pygame.K_r: start_reload()
                if event.key == pygame.K_1: current_weapon, is_reloading = WEAPON_PISTOL, False
                if event.key == pygame.K_2 and has_ak: current_weapon, is_reloading = WEAPON_AK, False

    if game_state == STATE_PLAYING:
        if current_weapon == WEAPON_AK and pygame.mouse.get_pressed()[0]: shoot()
        if damage_flash_timer > 0: damage_flash_timer -= 1
            
        if is_reloading and current_time >= reload_end:
            is_reloading = False
            if current_weapon == WEAPON_PISTOL: current_pistol_ammo = max_pistol_ammo
            else:
                taken = min(max_ak_ammo - current_ak_ammo, ak_reserve_ammo)
                current_ak_ammo += taken; ak_reserve_ammo -= taken
                
        if current_score - last_spawn_score >= 500: 
            spawn_amount = min(5, 2 + (current_score // 1000))
            if sum(1 for e in enemies if not e['dead']) < min(40, 15 + (current_score // 500) * 2): spawn_enemies(spawn_amount)
            last_spawn_score = current_score  
                
        if is_shooting:
            shoot_timer -= 1
            if shoot_timer <= 0: is_shooting = False
            
        if not player_dead:
            m_dx, m_dy = pygame.mouse.get_rel()
            player_angle += m_dx * 0.0015 * sens_mult * (0.5 if is_aiming else 1.0)
            player_pitch = max(-HEIGHT//2 + 50, min(HEIGHT//2 - 50, player_pitch - m_dy * 1.0 * sens_mult * (0.5 if is_aiming else 1.0)))
            
            dx, dy = 0, 0
            base_speed = player_speed * 0.5 if is_aiming else player_speed
            if (keys[pygame.K_w] or keys[pygame.K_s] or keys[pygame.K_a] or keys[pygame.K_d]) and (keys[pygame.K_LSHIFT] or keys[pygame.K_RSHIFT]) and player_stamina > 0 and not is_aiming:
                speed, player_stamina = base_speed * 1.5, max(0.0, player_stamina - 1.0) 
            else: speed, player_stamina = base_speed, min(max_stamina, player_stamina + 0.3) 
                
            if keys[pygame.K_w]: dx += math.cos(player_angle) * speed; dy += math.sin(player_angle) * speed
            if keys[pygame.K_s]: dx -= math.cos(player_angle) * speed; dy -= math.sin(player_angle) * speed
            if keys[pygame.K_a]: dx += math.sin(player_angle) * speed; dy -= math.cos(player_angle) * speed
            if keys[pygame.K_d]: dx -= math.sin(player_angle) * speed; dy += math.cos(player_angle) * speed
            check_collision(dx, dy)
            
            for item in items[:]:
                if math.hypot(player_x - item['x'], player_y - item['y']) < 40: 
                    if item['type'] == 'ak': has_ak, current_weapon, ak_reserve_ammo = True, WEAPON_AK, ak_reserve_ammo + 30
                    elif item['type'] == 'ammo': ak_reserve_ammo += 10
                    elif item['type'] == 'health': player_health = min(100.0, player_health + 25)
                    items.remove(item)

            for enemy in enemies:
                if enemy['dead']: continue

                dist_to_me = math.hypot(player_x - enemy['x'], player_y - enemy['y'])
                dist_to_other = math.hypot(other_pos["x"] - enemy['x'], other_pos["y"] - enemy['y']) if is_multiplayer and other_pos["x"] >= 0 else float('inf')

                if dist_to_me <= dist_to_other: tx, ty, dist = player_x, player_y, dist_to_me
                else: tx, ty, dist = other_pos["x"], other_pos["y"], dist_to_other

                if dist > 35:
                    mx, my = ((tx - enemy['x']) / max(1.0, dist)) * enemy['speed'], ((ty - enemy['y']) / max(1.0, dist)) * enemy['speed']
                    if is_safe(enemy['x'] + mx, enemy['y']): enemy['x'] += mx
                    if is_safe(enemy['x'], enemy['y'] + my): enemy['y'] += my
                else:
                    if dist_to_me <= 35 and current_time >= enemy['next_attack_time']:
                        enemy['next_attack_time'] = current_time + 1000  
                        if current_time >= player_invincible_end:
                            player_health -= 10.0; player_invincible_end = current_time + 700; damage_flash_timer = 20
                    
            if player_health <= 0: player_dead, game_state = True, STATE_GAMEOVER; pygame.event.set_grab(False); pygame.mouse.set_visible(True)

    virtual_screen.fill(BLACK) 
    virtual_screen.blit(bg_surface, (0, -HEIGHT//2 + player_pitch))
    
    start_angle = player_angle - (current_fov / 2)
    for ray in range(CASTED_RAYS):
        ray_angle = start_angle + ray * STEP_ANGLE
        sin_a, cos_a = math.sin(ray_angle), math.cos(ray_angle)
        for depth in range(1, int(MAX_DEPTH), 8):
            tx, ty = player_x + cos_a * depth, player_y + sin_a * depth
            if not (0 <= tx < MAP_W*TILE_SIZE and 0 <= ty < MAP_H*TILE_SIZE): break
            if MAP[int(ty / TILE_SIZE)][int(tx / TILE_SIZE)] == 1:
                ref_depth = depth - 7
                for _ in range(8):
                    if MAP[int((player_y + sin_a * ref_depth) / TILE_SIZE)][int((player_x + cos_a * ref_depth) / TILE_SIZE)] == 1:
                        draw_wall(ray, ref_depth, ray_angle); break
                    ref_depth += 1
                break

    # ⭐️ 복구된 렌더링 함수들 호출
    draw_bullet_holes()
    draw_entities()
    draw_damage_texts()
    if not player_dead: draw_weapon()
    draw_hud()
    draw_minimap()
    
    if damage_flash_timer > 0:
        fs = pygame.Surface((WIDTH, HEIGHT), pygame.SRCALPHA); fs.fill((255, 0, 0, min(30, int((damage_flash_timer / 20.0) * 30))))
        virtual_screen.blit(fs, (0, 0))
    
    if game_state == STATE_PAUSED:
        overlay = pygame.Surface((WIDTH, HEIGHT), pygame.SRCALPHA); overlay.fill((0, 0, 0, 180)); virtual_screen.blit(overlay, (0, 0))
        virtual_screen.blit(GO_FONT.render("PAUSED", True, WHITE), (WIDTH//2 - 150, 50))
        for btn, text in [(resume_btn_rect, "RESUME"), (restart_btn_rect, "RESTART"), (quit_btn_rect, "QUIT")]:
            pygame.draw.rect(virtual_screen, (80,80,80) if btn.collidepoint(get_virtual_mouse_pos(*pygame.mouse.get_pos())) else (50,50,50), btn, border_radius=10)
            virtual_screen.blit(PROG_FONT.render(text, True, WHITE), (btn.centerx - 40, btn.centery - 15))

    win_w, win_h = screen.get_size()
    ratio = min(win_w / WIDTH, win_h / HEIGHT)
    sw, sh = int(WIDTH * ratio), int(HEIGHT * ratio)
    screen.fill(BLACK) 
    screen.blit(pygame.transform.scale(virtual_screen, (sw, sh)), ((win_w - sw) // 2, (win_h - sh) // 2))
    pygame.display.flip()
    clock.tick(60)
